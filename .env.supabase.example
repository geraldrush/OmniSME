# Supabase-first environment template
# Copy to .env.supabase and fill values.

# --- Core DB (Supabase) ---
# Example:
# DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=

# DB fallback vars (used by some services directly)
DB_HOST=
DB_PORT=5432
DB_NAME=postgres
DB_USER=
DB_PASSWORD=

# --- Redis ---
REDIS_URL=redis://redis:6379

# --- Security ---
JWT_SECRET=replace-with-a-long-random-secret

# --- Public URLs ---
API_GATEWAY_URL=https://api.murek.co.za
ADMIN_PANEL_URL=https://admin.murek.co.za
CUSTOMER_STOREFRONT_URL=https://murek.co.za

# --- Monitoring ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-with-a-strong-password

# --- Optional payment/shipping integrations ---
PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
PAYFAST_PASSPHRASE=
OZOW_API_KEY=
SHIPLOGIC_API_KEY=
BOBGO_API_KEY=
PARGO_API_KEY=
JOB_BOARD_API_URL=
JOB_BOARD_API_KEY=
