# Supabase-first environment template
# Copy to .env.supabase and fill values.

# --- Core DB ---
# Example:
# DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=

# Optional DB fallback vars (used by some services if needed)
DB_HOST=
DB_PORT=5432
DB_NAME=postgres
DB_USER=
DB_PASSWORD=

# --- Security ---
JWT_SECRET=replace-with-a-long-random-secret

# --- Frontend/Public URLs ---
ADMIN_PANEL_URL=http://localhost:3100
CUSTOMER_STOREFRONT_URL=http://localhost:3101

# --- Internal service wiring ---
USER_SERVICE_URL=http://user-service:3001

# --- Optional payment/shipping integrations ---
PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
PAYFAST_PASSPHRASE=
OZOW_API_KEY=
SHIPLOGIC_API_KEY=
BOBGO_API_KEY=
PARGO_API_KEY=
JOB_BOARD_API_URL=
JOB_BOARD_API_KEY=

