# Database Configuration
DATABASE_URL=postgresql://sme_user:sme_password_dev@postgres:5432/sme_ecommerce
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=sme_user
DATABASE_PASSWORD=sme_password_dev
DATABASE_NAME=sme_ecommerce

# Redis Configuration
REDIS_URL=redis://redis:6379
REDIS_HOST=redis
REDIS_PORT=6379

# JWT Configuration
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRATION=86400

# PayFast Configuration (Get from PayFast dashboard)
PAYFAST_MERCHANT_ID=your_merchant_id
PAYFAST_MERCHANT_KEY=your_merchant_key
PAYFAST_PASSPHRASE=your_passphrase
PAYFAST_API_URL=https://api.payfast.co.za
PAYFAST_ITN_URL=/payment/payfast/notify

# Ozow Configuration (Get from Ozow dashboard)
OZOW_API_KEY=your_api_key
OZOW_API_URL=https://api.ozow.com
OZOW_WEBHOOK_URL=/payment/ozow/webhook

# Shipping Providers Configuration
# The Courier Guy / Ship Logic
SHIPLOGIC_API_KEY=your_shiplogic_api_key
SHIPLOGIC_API_URL=https://api.shiplogic.com

# Bob Go
BOBGO_API_KEY=your_bobgo_api_key
BOBGO_API_URL=https://api.bobgo.co.za

# Pargo
PARGO_API_KEY=your_pargo_api_key
PARGO_API_URL=https://api.pargo.co.za

# Email Configuration (for transactional emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@smeecommerce.local

# Application Configuration
NODE_ENV=development
APP_NAME=SME E-commerce Enabler
APP_URL=http://localhost:3000
ADMIN_PANEL_URL=http://localhost:3100
CUSTOMER_STOREFRONT_URL=http://localhost:3101

# API Configuration
API_PORT=3000
API_TIMEOUT=30000
API_RATE_LIMIT=100

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json

# Job Board Integration
JOB_BOARD_API_URL=https://api.jobboard.local
JOB_BOARD_API_KEY=your_job_board_api_key

# AWS/Azure Configuration (for file uploads when scaling)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
S3_BUCKET_NAME=sme-ecommerce-files

# Azure Configuration (Optional alternative to AWS)
AZURE_STORAGE_ACCOUNT_NAME=your_account_name
AZURE_STORAGE_ACCOUNT_KEY=your_account_key
AZURE_CONTAINER_NAME=sme-files

# Feature Flags
ENABLE_PAYFAST=true
ENABLE_OZOW=false
ENABLE_RECURRING_BILLING=false
ENABLE_JOB_BOARD=false
